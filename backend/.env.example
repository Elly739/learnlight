PORT=4000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=learnlight
# Railway/MySQL alternate names are also supported:
# MYSQLHOST=
# MYSQLPORT=
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLDATABASE=
JWT_SECRET=your_jwt_secret_here
ADMIN_EMAILS=iamellyokello@gmail.com
ALLOWED_ORIGINS=http://localhost:5173

# SQLite mode (recommended for local fallback/testing only)
FORCE_SQLITE=0
USE_SQLITE=false
ALLOW_SQLITE_FALLBACK=0
# Optional custom sqlite path:
# SQLITE_PATH=./data.sqlite

# Note: XAMPP default MySQL user is root with no password. Fill values before running.
